{
  "info": {
    "name": "GitHub Profile Analyzer API",
    "description": "Backend service that analyzes GitHub public profiles and stores insights in PostgreSQL.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://github-analyzer-eiwv.onrender.com",
      "type": "string"
    },
    {
      "key": "username",
      "value": "sadashivk47",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "response": []
    },
    {
      "name": "Analyze Profile (Fetch + Store)",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles/{{username}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles", "{{username}}"]
        },
        "description": "Fetches the GitHub profile + repos, computes insights, and stores/updates in the database. Add ?force=true as a query param to bypass the cache and re-fetch."
      },
      "response": []
    },
    {
      "name": "Get All Analyzed Profiles",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles?limit=20&page=1&sort=last_analyzed_at&order=desc",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles"],
          "query": [
            { "key": "limit", "value": "20" },
            { "key": "page", "value": "1" },
            { "key": "sort", "value": "last_analyzed_at" },
            { "key": "order", "value": "desc" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Single Profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles/{{username}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles", "{{username}}"]
        }
      },
      "response": []
    },
    {
      "name": "Get Profile Insight History",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles/{{username}}/history",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles", "{{username}}", "history"]
        }
      },
      "response": []
    },
    {
      "name": "Delete Profile",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles/{{username}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles", "{{username}}"]
        }
      },
      "response": []
    }
  ]
}
